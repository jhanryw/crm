# ============================================================
# QARVON CRM — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://crm.qarvon.com
NODE_ENV=production

# ─── Supabase (shared with ERP, separate schemas) ────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-instance.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_DB_URL=postgresql://postgres:password@db:5432/postgres

# ─── Auth (Supabase Auth) ────────────────────────────────────
NEXT_PUBLIC_SUPABASE_AUTH_REDIRECT_URL=https://crm.qarvon.com/auth/callback

# ─── WhatsApp Cloud API ──────────────────────────────────────
# Meta App credentials
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_VERIFY_TOKEN=your_webhook_verify_token_whatsapp

# WhatsApp Business Account
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id

# Default phone number (can be overridden per workspace)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token

# ─── Instagram Direct ────────────────────────────────────────
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret
INSTAGRAM_VERIFY_TOKEN=your_webhook_verify_token_instagram

# ─── Meta Conversions API (CAPI) ────────────────────────────
META_PIXEL_ID=your_pixel_id
META_CAPI_ACCESS_TOKEN=your_capi_access_token
META_TEST_EVENT_CODE=TEST12345

# ─── Google Ads ──────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
GOOGLE_ADS_CLIENT_ID=your_oauth_client_id
GOOGLE_ADS_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token
GOOGLE_ADS_CUSTOMER_ID=your_customer_id

# ─── ERP Integration ────────────────────────────────────────
# The ERP is a separate service — communicate via its API only
ERP_BASE_URL=https://erp.qarvon.com
ERP_WEBHOOK_SECRET=shared_hmac_secret_between_crm_and_erp
ERP_API_KEY=your_erp_internal_api_key

# ─── Security ───────────────────────────────────────────────
WEBHOOK_SECRET_SALT=random_32_char_string_for_hmac
NEXTAUTH_SECRET=random_64_char_string_for_jwt

# ─── Redis (optional, for job queue) ────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Worker ─────────────────────────────────────────────────
WORKER_CRON_SCORING=*/15 * * * *
WORKER_CRON_CAPI_FLUSH=*/5 * * * *
WORKER_CRON_TEMPERATURE=0 * * * *
